.hero {
  position: relative;
  height: 392rpx;
}

.hero-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  height: 100%;
  padding: 42rpx;
  flex-direction: column;
  justify-content: flex-end;
  background: linear-gradient(90deg, rgba(255, 251, 239, 0.92) 0%, rgba(255, 251, 239, 0.5) 56%, rgba(255, 251, 239, 0.08) 100%);
}

.hero-kicker {
  color: #658358;
  font-size: 24rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 12rpx;
  color: #2E3A2D;
  font-size: 48rpx;
  font-weight: 900;
}

.hero-subtitle {
  margin-top: 14rpx;
  color: #806C4B;
  font-size: 26rpx;
}

.summary-grid {
  display: flex;
  margin-top: 24rpx;
}

.summary-grid forest-card {
  width: 31.5%;
  margin-right: 2.75%;
}

.summary-grid forest-card:last-child {
  margin-right: 0;
}

.quick-grid {
  display: flex;
  margin-top: 24rpx;
}

.quick-action {
  width: 48.5%;
  min-height: 172rpx;
  margin-right: 3%;
  padding: 26rpx;
  border-radius: 28rpx;
  text-align: left;
  background: rgba(255, 251, 239, 0.86);
  box-shadow: 0 16rpx 34rpx rgba(78, 94, 61, 0.1);
}

.quick-action:last-child {
  margin-right: 0;
}

.quick-icon {
  display: block;
  font-size: 44rpx;
}

.quick-title {
  display: block;
  margin-top: 12rpx;
  color: #344032;
  font-size: 30rpx;
  font-weight: 800;
}

.quick-desc {
  display: block;
  margin-top: 8rpx;
  color: #8A7B63;
  font-size: 24rpx;
}

.record-list {
  padding: 10rpx 24rpx;
}

.record-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 2rpx solid rgba(115, 93, 58, 0.08);
  justify-content: space-between;
}

.record-item:last-child {
  border-bottom: 0;
}

.record-main,
.record-side {
  display: flex;
  flex-direction: column;
}

.record-side {
  align-items: flex-end;
}

.record-title {
  color: #344032;
  font-size: 30rpx;
  font-weight: 800;
}

.record-note,
.record-date {
  margin-top: 8rpx;
  color: #8A7B63;
  font-size: 23rpx;
}

.record-amount {
  font-size: 30rpx;
  font-weight: 800;
}

.guardian-card {
  display: flex;
  margin-top: 26rpx;
  padding: 20rpx 24rpx;
  align-items: center;
}

.guardian {
  width: 150rpx;
  height: 150rpx;
  flex: none;
}

.guardian-copy {
  margin-left: 20rpx;
}

.guardian-title {
  display: block;
  color: #344032;
  font-size: 30rpx;
  font-weight: 800;
}

.guardian-text {
  display: block;
  margin-top: 10rpx;
  color: #7E735F;
  font-size: 25rpx;
  line-height: 1.5;
}

