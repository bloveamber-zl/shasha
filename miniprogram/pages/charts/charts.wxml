<view class="page charts-page">
  <view class="chart-hero paper-card">
    <view>
      <text class="chart-kicker">森林观察板</text>
      <text class="chart-title">本月支出 {{summary.expense}}</text>
      <text class="chart-desc">结余 {{summary.balance}}，日均支出 {{summary.dailyAverage}}</text>
    </view>
    <image class="chart-mascot" src="{{guardianImage}}" mode="aspectFit" />
  </view>

  <view class="section-title">
    <text>最近趋势</text>
    <text class="muted">支出</text>
  </view>
  <view class="trend-card paper-card">
    <view class="trend-item" wx:for="{{trend}}" wx:key="date">
      <view class="bar-wrap">
        <view class="trend-bar" style="height: {{item.height}}rpx;"></view>
      </view>
      <text class="trend-date">{{item.date}}</text>
      <text class="trend-value">{{item.expense}}</text>
    </view>
  </view>

  <view class="section-title">
    <text>分类占比</text>
    <text class="muted">支出排行</text>
  </view>
  <view class="category-card paper-card">
    <view class="category-stat" wx:for="{{categoryStats}}" wx:key="category">
      <view class="category-head">
        <text class="category-name">{{item.icon}} {{item.category}}</text>
        <text class="category-amount">{{item.amount}}</text>
      </view>
      <view class="progress-track">
        <view class="progress-fill" style="width: {{item.percent}}%; background: {{item.color}};"></view>
      </view>
      <text class="category-percent">{{item.percent}}%</text>
    </view>
  </view>
</view>

