.export-hero {
  display: flex;
  min-height: 248rpx;
  padding: 32rpx;
  align-items: center;
  justify-content: space-between;
}

.hero-copy {
  min-width: 0;
}

.hero-kicker,
.hero-desc {
  display: block;
  color: #8A7B63;
  font-size: 24rpx;
  line-height: 1.45;
}

.hero-title {
  display: block;
  margin: 12rpx 0;
  color: #344032;
  font-size: 46rpx;
  font-weight: 900;
}

.hero-desc {
  max-width: 430rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-image {
  width: 164rpx;
  height: 164rpx;
  flex: none;
}

.filter-card {
  margin-top: 24rpx;
  padding: 20rpx;
}

.date-filter {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.date-filter-item {
  display: flex;
  min-height: 76rpx;
  padding: 0 18rpx;
  border-radius: 22rpx;
  align-items: center;
  justify-content: space-between;
  color: #344032;
  font-size: 25rpx;
  font-weight: 800;
  background: rgba(107, 139, 89, 0.1);
}

.date-filter-item text:last-child {
  color: #8A7B63;
  font-weight: 600;
}

.quick-actions {
  display: grid;
  margin-top: 18rpx;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.quick-actions button,
.copy-button {
  display: flex;
  height: 58rpx;
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  color: #4F6D45;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 58rpx;
  background: rgba(107, 139, 89, 0.12);
}

.summary-card {
  display: grid;
  margin-top: 24rpx;
  padding: 24rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.summary-item {
  min-height: 104rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 251, 239, 0.72);
}

.summary-item.full {
  grid-column: 1 / -1;
}

.summary-label {
  display: block;
  color: #8A7B63;
  font-size: 23rpx;
  font-weight: 700;
}

.summary-value {
  display: block;
  margin-top: 10rpx;
  color: #344032;
  font-size: 32rpx;
  font-weight: 900;
  overflow-wrap: anywhere;
}

.export-button {
  margin-top: 28rpx;
}

.path-card {
  margin-top: 24rpx;
  padding: 24rpx;
}

.path-title {
  display: block;
  color: #344032;
  font-size: 28rpx;
  font-weight: 900;
}

.path-text {
  display: block;
  margin-top: 12rpx;
  color: #8A7B63;
  font-size: 23rpx;
  line-height: 1.45;
  overflow-wrap: anywhere;
}

.copy-button {
  margin-top: 18rpx;
}

.preview-list {
  padding: 4rpx 24rpx;
}

.preview-item {
  display: flex;
  min-height: 116rpx;
  padding: 22rpx 0;
  border-bottom: 2rpx solid rgba(115, 93, 58, 0.08);
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.preview-item:last-child {
  border-bottom: 0;
}

.preview-main {
  min-width: 0;
  flex: 1;
}

.preview-title {
  display: block;
  color: #344032;
  font-size: 29rpx;
  font-weight: 900;
}

.preview-desc,
.preview-note {
  display: block;
  margin-top: 8rpx;
  color: #8A7B63;
  font-size: 23rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preview-note {
  color: #5D8A61;
}

.preview-amount {
  flex: none;
  font-size: 28rpx;
  font-weight: 900;
}

.empty-card {
  display: flex;
  padding: 34rpx;
  align-items: center;
  flex-direction: column;
  text-align: center;
}

.empty-image {
  width: 190rpx;
  height: 190rpx;
}

.empty-title {
  margin-top: 12rpx;
  color: #344032;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-desc {
  margin-top: 8rpx;
  color: #8A7B63;
  font-size: 24rpx;
  line-height: 1.5;
}
