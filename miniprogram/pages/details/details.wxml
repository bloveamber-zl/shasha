<view class="page details-page">
  <view class="filter-card paper-card">
    <view class="type-filter">
      <button
        wx:for="{{typeTabs}}"
        wx:key="value"
        class="filter-tab {{activeType === item.value ? 'active' : ''}}"
        bindtap="onTypeTap"
        data-type="{{item.value}}"
      >
        {{item.label}}
      </button>
    </view>
    <picker mode="selector" range="{{categoryNames}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
      <view class="category-filter">
        <text>分类筛选</text>
        <text>{{categoryNames[categoryIndex]}}</text>
      </view>
    </picker>
    <picker mode="selector" range="{{accountNames}}" value="{{accountIndex}}" bindchange="onAccountChange">
      <view class="category-filter">
        <text>账户筛选</text>
        <text>{{accountNames[accountIndex]}}</text>
      </view>
    </picker>
    <picker mode="selector" range="{{tagNames}}" value="{{tagIndex}}" bindchange="onTagChange">
      <view class="category-filter">
        <text>标签筛选</text>
        <text>{{tagNames[tagIndex]}}</text>
      </view>
    </picker>
    <view class="date-filter">
      <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
        <view class="date-filter-item">
          <text>开始</text>
          <text>{{startDate || '不限'}}</text>
        </view>
      </picker>
      <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
        <view class="date-filter-item">
          <text>结束</text>
          <text>{{endDate || '不限'}}</text>
        </view>
      </picker>
    </view>
    <button class="clear-filter" bindtap="clearFilters">清空筛选</button>
  </view>

  <view class="summary-card paper-card">
    <view class="summary-item" wx:for="{{summaryCards}}" wx:key="label">
      <text class="summary-label">{{item.label}}</text>
      <text class="summary-value">{{item.value}}</text>
    </view>
    <button class="top-category" bindtap="applyTopCategory">
      <text>最大支出分类</text>
      <text>{{topCategory}} · {{topCategoryAmount}}</text>
    </button>
  </view>

  <view class="empty-card paper-card" wx:if="{{groups.length === 0}}">
    <image class="empty-image" src="/assets/images/forest-guardian.png" mode="aspectFit" />
    <text class="empty-title">这片森林还没有账单</text>
    <text class="empty-desc">换个筛选条件，或先去记一笔。</text>
  </view>

  <view class="date-group" wx:for="{{groups}}" wx:key="date">
    <view class="section-title">
      <text>{{item.date}}</text>
      <text class="muted">{{item.records.length}} 笔</text>
    </view>
    <view class="record-list paper-card">
      <view class="record-item" wx:for="{{item.records}}" wx:for-item="record" wx:key="id">
        <view>
          <text class="record-title">{{record.category}}</text>
          <text class="record-note">{{record.note || record.account}}</text>
          <text class="record-tags" wx:if="{{record.tags.length > 0}}">{{record.tagText}}</text>
        </view>
        <view class="record-side">
          <text class="{{record.amountClass}} record-amount">{{record.displayAmount}}</text>
          <text class="record-account">{{record.account}}</text>
          <view class="record-actions">
            <button bindtap="editRecord" data-id="{{record.id}}">编辑</button>
            <button class="danger" bindtap="deleteRecord" data-id="{{record.id}}">删除</button>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
