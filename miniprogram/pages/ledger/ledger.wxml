<view class="page ledger-page">
  <view class="edit-banner paper-card" wx:if="{{isEditing}}">
    <text class="edit-title">正在编辑一笔账</text>
    <text class="edit-desc">修改后会覆盖原记录，刷新后仍从云端读取。</text>
  </view>

  <view class="amount-panel paper-card">
    <view class="type-tabs">
      <button
        wx:for="{{typeTabs}}"
        wx:key="value"
        class="type-tab {{activeType === item.value ? 'active' : ''}}"
        bindtap="onTypeTap"
        data-type="{{item.value}}"
      >
        {{item.label}}
      </button>
    </view>
    <view class="amount-input-row">
      <text class="currency">¥</text>
      <input class="amount-input" type="digit" value="{{amountText}}" placeholder="0.00" bindinput="onAmountInput" />
    </view>
  </view>

  <view class="section-title">
    <text>分类</text>
    <text class="muted">{{activeCategory}}</text>
  </view>
  <view class="category-grid">
    <button
      wx:for="{{categories}}"
      wx:key="id"
      class="category-item {{activeCategory === item.name ? 'active' : ''}}"
      bindtap="onCategoryTap"
      data-name="{{item.name}}"
    >
      <text class="category-icon">{{item.icon}}</text>
      <text class="category-name">{{item.name}}</text>
    </button>
  </view>

  <view class="form-card paper-card">
    <picker mode="selector" range="{{accounts}}" value="{{accountIndex}}" bindchange="onAccountChange">
      <view class="form-row">
        <text>账户</text>
        <text class="form-value">{{accounts[accountIndex]}}</text>
      </view>
    </picker>
    <picker mode="date" value="{{date}}" bindchange="onDateChange">
      <view class="form-row">
        <text>日期</text>
        <text class="form-value">{{date}}</text>
      </view>
    </picker>
    <view class="date-shortcuts">
      <button bindtap="onDatePresetTap" data-preset="today">今天</button>
      <button bindtap="onDatePresetTap" data-preset="yesterday">昨天</button>
    </view>
    <view class="note-row">
      <text>标签</text>
      <input class="tag-input" value="{{tagText}}" placeholder="午餐，通勤，可用逗号分隔" bindinput="onTagInput" />
      <view class="tag-presets" wx:if="{{tagOptions.length > 0}}">
        <button wx:for="{{tagOptions}}" wx:key="*this" bindtap="onTagPresetTap" data-tag="{{item}}">{{item}}</button>
      </view>
    </view>
    <view class="note-row">
      <text>备注</text>
      <textarea value="{{note}}" auto-height maxlength="40" placeholder="写点什么，月底会感谢你" bindinput="onNoteInput" />
    </view>
  </view>

  <button class="primary-button save-button" bindtap="saveRecord">{{saveButtonText}}</button>

  <view class="success-card paper-card" wx:if="{{lastSaved}}">
    <image src="{{successImage}}" class="success-image" mode="aspectFit" />
    <view class="success-copy">
      <text class="success-title">刚刚记录</text>
      <text class="success-text">{{lastSaved.category}} · {{lastSaved.account}} · {{lastSaved.date}}</text>
    </view>
  </view>
</view>
