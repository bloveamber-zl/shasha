page {
  min-height: 100vh;
  color: #2F372D;
  background: linear-gradient(180deg, #F7F1DF 0%, #F9F5EA 42%, #EEF6EA 100%);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  line-height: 1;
  background: transparent;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 180rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 34rpx 0 18rpx;
  color: #344032;
  font-size: 34rpx;
  font-weight: 700;
}

.muted {
  color: #8A7B63;
}

.paper-card {
  overflow: hidden;
  border: 2rpx solid rgba(115, 93, 58, 0.08);
  border-radius: 28rpx;
  background: rgba(255, 251, 239, 0.92);
  box-shadow: 0 18rpx 42rpx rgba(78, 94, 61, 0.11);
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 999rpx;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #5EA56B 0%, #3F8E72 100%);
  box-shadow: 0 14rpx 30rpx rgba(70, 139, 94, 0.22);
}

.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  border: 2rpx solid rgba(93, 126, 82, 0.18);
  border-radius: 999rpx;
  color: #4F6D45;
  font-size: 28rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.62);
}

.amount-income {
  color: #329081;
}

.amount-expense {
  color: #DD7657;
}
